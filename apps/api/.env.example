# ---- App ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins for the web app
CORS_ORIGINS=http://localhost:3000

# ---- Database (Prisma / PostgreSQL) ----
DATABASE_URL="postgresql://edufees:edufees@localhost:5432/edufees?schema=public"
# Neon/pooled setups use a separate direct URL for migrations; locally it is the same.
DIRECT_URL="postgresql://edufees:edufees@localhost:5432/edufees?schema=public"

# ---- Auth (JWT) ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- Redis / BullMQ ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Storage provider ----
# "local" writes to STORAGE_LOCAL_DIR and serves signed-style URLs; "s3" uses AWS.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
STORAGE_PUBLIC_BASE_URL=http://localhost:4000/files
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Messaging provider ----
# "console" logs messages; swap for real WhatsApp/Email/SMS providers later.
MESSAGING_DRIVER=console

# ---- Payment gateway ----
# "mock" simulates orders/payments; swap for razorpay/payu/stripe later.
PAYMENT_DRIVER=mock
