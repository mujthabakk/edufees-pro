{
  "name": "edufees-pro",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @edufees/web",
    "dev:api": "npm run start:dev --workspace @edufees/api",
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "build:shared": "npm run build --workspace @edufees/shared-types",
    "build:web": "npm run build --workspace @edufees/web",
    "build:api": "npm run build --workspace @edufees/api",
    "lint": "npm run lint:web && npm run lint:api",
    "lint:web": "npm run lint --workspace @edufees/web",
    "lint:api": "npm run lint --workspace @edufees/api",
    "deploy:web": "npm run deploy --workspace @edufees/web",
    "db:generate": "npm run db:generate --workspace @edufees/api",
    "db:migrate": "npm run db:migrate --workspace @edufees/api",
    "db:seed": "npm run db:seed --workspace @edufees/api"
  }
}
